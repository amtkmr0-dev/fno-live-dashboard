# FNO Dashboard Configuration Template
# Copy this file to config.env and fill in your actual values
# NEVER commit config.env to git!

# Upstox API Configuration
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here

# AI Chat Configuration (Perplexity)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# AI Chat Configuration (NVIDIA NIM - Alternative)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
PROXY_PORT=8080

# Database
DATABASE_PATH=quantra.db

# Session Configuration
SESSION_MAX_AGE=86400
SESSION_SECRET=generate_a_random_secret_here

# Security
CSRF_SECRET=generate_another_random_secret_here
RATE_LIMIT_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=server.log
AUDIT_LOG_FILE=audit.log

# Optional: Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Email Verification (Resend.com — free, 3000 emails/month)
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sender address — use onboarding@resend.dev to test without a domain,
# or set your own verified domain address (e.g. noreply@quantra.in)
RESEND_FROM=noreply@resend.dev

# Payment Gateway (Razorpay)
# Get your keys at: https://dashboard.razorpay.com/app/keys
# Use rzp_test_... keys for testing, rzp_live_... for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# Webhook secret — find in Razorpay Dashboard > Webhooks (optional, needed for auto-renewals)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
